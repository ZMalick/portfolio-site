# Copy to .env.local and fill in. .env.local is gitignored — never commit real secrets.
# All three are SERVER-SIDE ONLY. They must never appear in the client bundle.

# Groq API key for the /api/chat route (llama-3.3-70b-versatile, free tier, no card).
# Generate a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Upstash Redis — per-IP rate limiting on the public chat endpoint.
# Create a free DB at upstash.com, then copy the REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
